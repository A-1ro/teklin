{
  "name": "@teklin/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply teklin-db --local"
  },
  "dependencies": {
    "@teklin/shared": "*",
    "drizzle-orm": "^0.41.0",
    "hono": "^4.7.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250410.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.8.3",
    "wrangler": "^4.10.0"
  }
}
